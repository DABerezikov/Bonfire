<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:Bonfire.Infrastructure.Converters">

    <conv:NullToVisibilityConverter        x:Key="NullToVisibilityConverter"/>
    <conv:NotNullToVisibilityConverter     x:Key="NotNullToVisibilityConverter"/>
    <conv:StringToBrushConverter           x:Key="StringToBrushConverter"/>
    <BooleanToVisibilityConverter          x:Key="BoolToVisibility"/>
    <conv:NotBoolToVisibilityConverter     x:Key="NotBoolToVisibility"/>
    <conv:PxToMetersConverter              x:Key="PxToMeters"/>

</ResourceDictionary>
