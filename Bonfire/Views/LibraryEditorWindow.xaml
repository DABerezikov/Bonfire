<UserControl x:Class="Bonfire.Views.LibraryEditorWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Bonfire.ViewModels"
             xmlns:m="clr-namespace:Bonfire.Models"
             d:DataContext="{d:DesignInstance {x:Type vm:LibraryEditorViewModel}}"
             d:DesignHeight="1080" d:DesignWidth="1920">
    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource LibraryBorderStyle}"/>
        <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource LibraryBorderStyle}"/>
        <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource LibraryBorderStyle}"/>

        <!-- Список сортов -->
        <DataGrid Grid.Column="0" Grid.Row="0" IsReadOnly="True" SelectionMode="Single"
                  ItemsSource="{Binding Sort}" Margin="15"
                  ColumnHeaderStyle="{StaticResource CenterGridHeaderStyle}"
                  SelectedItem="{Binding SelectedSort}">
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="*">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="Библиотека сортов" Style="{StaticResource LibraryTextBlockStyle}"/>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="{x:Type m:SortFromSeedsViewModel}">
                            <TextBlock Text="{Binding Name}" Padding="4,2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Список культур -->
        <DataGrid Grid.Column="1" Grid.Row="0" IsReadOnly="True" SelectionMode="Single"
                  ItemsSource="{Binding Culture}" Margin="15"
                  ColumnHeaderStyle="{StaticResource CenterGridHeaderStyle}"
                  SelectedItem="{Binding SelectedCulture}">
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="*">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="Библиотека культур" Style="{StaticResource LibraryTextBlockStyle}"/>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="{x:Type m:CultureFromViewModel}">
                            <TextBlock Text="{Binding Name}" Padding="4,2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Список производителей -->
        <DataGrid Grid.Column="2" Grid.Row="0" IsReadOnly="True" SelectionMode="Single"
                  ItemsSource="{Binding Producer}" Margin="15"
                  ColumnHeaderStyle="{StaticResource CenterGridHeaderStyle}"
                  SelectedItem="{Binding SelectedProducer}">
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="*">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="Библиотека производителей" Style="{StaticResource LibraryTextBlockStyle}"/>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="{x:Type m:ProducerFromViewModel}">
                            <TextBlock Text="{Binding Name}" Padding="4,2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Детальная панель (Row 2, все 3 колонки) -->
        <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Margin="5,0,5,5">

            <!-- Форма редактирования сорта -->
            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="8" Padding="10,8"
                    Visibility="{Binding SortDetail, Converter={StaticResource NullToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Строка 0: Название, Описание -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" VerticalAlignment="Center" Margin="0,3,6,3"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Margin="0,3"
                             Text="{Binding SortDetail.Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Описание:" VerticalAlignment="Center" Margin="0,3,6,3"/>
                    <TextBox Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="4" Margin="0,3"
                             Text="{Binding SortDetail.Description, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Строка 1: Вегетация мин/макс, Возраст рассады -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Вегетация мин., дн.:" VerticalAlignment="Center" Margin="0,3,6,3"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Margin="0,3"
                             Text="{Binding SortDetail.MinGerminationTime, UpdateSourceTrigger=PropertyChanged,
                                    TargetNullValue='', ValidatesOnDataErrors=True, ValidatesOnExceptions=True}"/>
                    <TextBlock Grid.Row="1" Grid.Column="3" Text="Вегетация макс., дн.:" VerticalAlignment="Center" Margin="0,3,6,3"/>
                    <TextBox Grid.Row="1" Grid.Column="4" Margin="0,3"
                             Text="{Binding SortDetail.MaxGerminationTime, UpdateSourceTrigger=PropertyChanged,
                                    TargetNullValue='', ValidatesOnDataErrors=True, ValidatesOnExceptions=True}"/>
                    <TextBlock Grid.Row="1" Grid.Column="6" Text="Возраст рассады, дн.:" VerticalAlignment="Center" Margin="0,3,6,3"/>
                    <TextBox Grid.Row="1" Grid.Column="7" Margin="0,3"
                             Text="{Binding SortDetail.AgeOfSeedlings, UpdateSourceTrigger=PropertyChanged,
                                    TargetNullValue='', ValidatesOnExceptions=True}"/>

                    <!-- Строка 2: Вегет. период, Схема посадки, Высота -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Вегет. период, дн.:" VerticalAlignment="Center" Margin="0,3,6,3"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Margin="0,3"
                             Text="{Binding SortDetail.GrowingSeason, UpdateSourceTrigger=PropertyChanged,
                                    TargetNullValue='', ValidatesOnExceptions=True}"/>
                    <TextBlock Grid.Row="2" Grid.Column="3" Text="Схема посадки, см:" VerticalAlignment="Center" Margin="0,3,6,3"/>
                    <TextBox Grid.Row="2" Grid.Column="4" Margin="0,3"
                             Text="{Binding SortDetail.LandingPattern, UpdateSourceTrigger=PropertyChanged,
                                    TargetNullValue='', ValidatesOnExceptions=True}"/>
                    <TextBlock Grid.Row="2" Grid.Column="6" Text="Высота растения, см:" VerticalAlignment="Center" Margin="0,3,6,3"/>
                    <TextBox Grid.Row="2" Grid.Column="7" Margin="0,3"
                             Text="{Binding SortDetail.PlantHeight, UpdateSourceTrigger=PropertyChanged,
                                    TargetNullValue='', ValidatesOnExceptions=True}"/>

                    <!-- Строка 3: Цвет, кнопки -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Цвет (#RRGGBB):" VerticalAlignment="Center" Margin="0,3,6,3"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Margin="0,3"
                             Text="{Binding SortDetail.PlantColor, UpdateSourceTrigger=PropertyChanged}"/>
                    <StackPanel Grid.Row="3" Grid.Column="6" Grid.ColumnSpan="2"
                                Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,3">
                        <Button Content="Сохранить" Command="{Binding SaveSortCommand}" MinWidth="90" Margin="0,0,8,0"/>
                        <Button Content="Отмена" Command="{Binding CancelSortCommand}" MinWidth="90"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Форма редактирования культуры -->
            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="8" Padding="10,8"
                    Visibility="{Binding CultureDetail, Converter={StaticResource NullToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Название:" VerticalAlignment="Center" Margin="0,3,6,3"/>
                    <TextBox Grid.Column="1" Margin="0,3"
                             Text="{Binding CultureDetail.Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>
                    <TextBlock Grid.Column="3" Text="Класс:" VerticalAlignment="Center" Margin="0,3,6,3"/>
                    <ComboBox Grid.Column="4" Margin="0,3"
                              ItemsSource="{Binding ClassList}"
                              SelectedItem="{Binding CultureDetail.Class}"/>
                    <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,3">
                        <Button Content="Сохранить" Command="{Binding SaveCultureCommand}" MinWidth="90" Margin="0,0,8,0"/>
                        <Button Content="Отмена" Command="{Binding CancelCultureCommand}" MinWidth="90"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Форма редактирования производителя -->
            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="8" Padding="10,8"
                    Visibility="{Binding SelectedProducer, Converter={StaticResource NullToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Название:" VerticalAlignment="Center" Margin="0,3,6,3"/>
                    <TextBox Grid.Column="1" Margin="0,3"
                             Text="{Binding ProducerDetailName, UpdateSourceTrigger=PropertyChanged}"/>
                    <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,3">
                        <Button Content="Сохранить" Command="{Binding SaveProducerCommand}" MinWidth="90" Margin="0,0,8,0"/>
                        <Button Content="Отмена" Command="{Binding CancelProducerCommand}" MinWidth="90"/>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>

    </Grid>
</UserControl>
