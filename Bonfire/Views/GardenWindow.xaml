<UserControl x:Class="Bonfire.Views.GardenWindow"
                          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" mc:Ignorable="d" 
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Bonfire.ViewModels"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:templates="clr-namespace:Bonfire.Templates"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             d:DataContext="{d:DesignInstance {x:Type vm:GardenViewModel}}"
             d:DesignHeight="1080" d:DesignWidth="1920" >

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadDataCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>



    <Grid Margin="10">

        <Grid.RowDefinitions>
           
            <RowDefinition />
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="110"/>
            <ColumnDefinition Width="930"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>







       
        <Border Grid.Row="0" Grid.Column="0" CornerRadius="10" Style="{StaticResource SeedsBorderStyle}" Grid.ColumnSpan="3"
                Grid.RowSpan="3" />
        
        <Border Grid.Row="0" Grid.Column="3" CornerRadius="10" Style="{StaticResource SeedsBorderStyle}" HorizontalAlignment="Stretch"
         Margin="10,0,10,10" VerticalAlignment="Stretch" Grid.RowSpan="2"/>

       
        <Border Grid.Row="2" Grid.Column="3" CornerRadius="10" Style="{StaticResource SeedsBorderStyle}" HorizontalAlignment="Stretch"
         Margin="10,0,10,0" />

        <Grid Grid.Column="0" Grid.Row="0" Grid.RowSpan="3" Grid.ColumnSpan="3"  Background="#A08E80" HorizontalAlignment="Stretch" Margin="5" Name="Grid"  >
            
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="MouseMove">
                    <i:InvokeCommandAction Command="{Binding MouseMoveCommand}" 
                                           CommandParameter="{Binding ElementName=Grid}"/>
                </i:EventTrigger>
                <i:EventTrigger EventName="MouseDown">
                    <i:InvokeCommandAction Command="{Binding MouseDownCommand}"
                                           CommandParameter="{Binding ElementName=Grid}"/>
                </i:EventTrigger>
                <i:EventTrigger EventName="MouseUp">
                    <i:InvokeCommandAction Command="{Binding MouseUpCommand}"
                                           CommandParameter="{Binding ElementName=Grid}"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>

            <ItemsControl ItemsSource="{Binding SeedBeds}" Width="1050" Height="1000">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas IsItemsHost="True" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>


                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <Rectangle Width="{Binding Width}"
                                   Height="{Binding Height}"
                                   Fill="{Binding DataContext.FillSeedbed, RelativeSource={RelativeSource AncestorType=UserControl, Mode=FindAncestor}}"
                                   Stroke="{Binding DataContext.StrokeSeedbed, RelativeSource={RelativeSource AncestorType=UserControl, Mode=FindAncestor}}"
                                   StrokeThickness="{Binding DataContext.StrokeThicknessSeedbed, RelativeSource={RelativeSource AncestorType=UserControl, Mode=FindAncestor}}">

                            <Rectangle.Style>
                               
                                    <Style TargetType="Rectangle">
                                        <Setter Property="Stroke" Value="{Binding Stroke}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <DataTrigger.Setters>
                                                   <Setter Property="Stroke" Value="Aqua"></Setter>
                                                </DataTrigger.Setters>
                                                
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                
                            </Rectangle.Style>
                        </Rectangle>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                <ItemsControl.ItemContainerStyle>
                    <Style>
                        <Setter Property="Canvas.Left" Value="{Binding Position.X}"/>
                        <Setter Property="Canvas.Top" Value="{Binding Position.Y}"/>
                       
                    </Style>
                    
                </ItemsControl.ItemContainerStyle>

            </ItemsControl>
            

        </Grid>





        
        <TextBox Grid.Column="3" Grid.Row="2" Style="{StaticResource SeedsTextBoxStyle}" Text="{Binding CurrentWidth}" Margin="20,70,0,0" />
        <TextBox Grid.Column="3" Grid.Row="2" Style="{StaticResource SeedsTextBoxStyle}" Text="{Binding CurrentHeight}" Margin="150,70,0,0" />
        <CheckBox Grid.Column="3" Grid.Row="2" Content="Постоянная" Margin="280,70,0,0" Width="150" Height="24" HorizontalAlignment="Left" VerticalAlignment="Top"
                  IsChecked="{Binding IsRegularSeedbed}"/>
        <Button Grid.Row="2" Grid.Column="3" Margin="20,20,0,0" Style="{StaticResource SeedsButtonStyle}" Width="24" Background="{Binding CreateButtonPressedColor}" FontSize="18" 
                Command="{Binding IsCreateSeedBedCommand}">
            
            <Button.Content>
                <Image Source="Image/rectangle.png" ToolTip="Нарисовать грядку"/>
               
            </Button.Content>
            
        </Button>

        <Button Grid.Row="2" Grid.Column="3" Margin="50,20,0,0" Style="{StaticResource SeedsButtonStyle}" Width="24" Background="{Binding MoveButtonPressedColor}" FontSize="18" 
                Command="{Binding IsMoveSeedBedCommand}">

            <Button.Content>
                <Image Source="Image/movepointer.png"  ToolTip="Переместить грядку" />

            </Button.Content>

        </Button>



    </Grid>
</UserControl>
