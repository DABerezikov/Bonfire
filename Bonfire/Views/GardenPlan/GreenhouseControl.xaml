<UserControl x:Class="Bonfire.Views.GardenPlan.GreenhouseControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:m="clr-namespace:Bonfire.Models"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance {x:Type m:GreenhouseFromViewModel}}"
             Width="{Binding DisplayWidth}" Height="{Binding DisplayHeight}">
    <UserControl.Style>
        <Style TargetType="UserControl">
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLocked}" Value="True">
                    <Setter Property="Cursor" Value="Arrow"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <!--
        Tag содержит GardenPlanViewModel (прокинут из DataTemplate в GardenPlanView).
        Используем его для привязки команд вместо навигации по дереву.
    -->
    <i:Interaction.Triggers>
        <!-- Двойной клик — открыть внутреннее пространство теплицы -->
        <i:EventTrigger EventName="MouseDoubleClick">
            <i:InvokeCommandAction
                Command="{Binding Tag.OpenGreenhouseCommand,
                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Border Background="#F3E5F5" CornerRadius="6" Padding="6,4">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="BorderBrush" Value="#7B1FA2"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter Property="BorderThickness" Value="3"/>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#7B1FA2" BlurRadius="10" ShadowDepth="0"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <DockPanel>
                <!-- Иконка + название -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                    <TextBlock Text="🏠" FontSize="13" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="11"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Top" FontSize="10" Foreground="#9C27B0">
                    <Run Text="{Binding WidthMeters, StringFormat={}{0:F0}}"/>
                    <Run Text="×"/>
                    <Run Text="{Binding HeightMeters, StringFormat={}{0:F0}}"/>
                    <Run Text=" м"/>
                </TextBlock>

                <!-- Статус -->
                <Border DockPanel.Dock="Bottom"
                        Background="{Binding StateColor, Converter={StaticResource StringToBrushConverter}}"
                        CornerRadius="3" Padding="3,1" HorizontalAlignment="Left" Margin="0,4,0,0">
                    <TextBlock Text="{Binding StateDisplayName}" Foreground="White" FontSize="9"/>
                </Border>

                <!-- Подсказка двойного клика -->
                <TextBlock DockPanel.Dock="Bottom" Text="[двойной клик — открыть]"
                           FontSize="9" Foreground="#9E9E9E" Margin="0,2,0,0"/>
            </DockPanel>
        </Border>

        <!-- Кнопка замка — верхний правый угол -->
        <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                Width="20" Height="20" Panel.ZIndex="12" Padding="0"
                Cursor="Arrow" Background="Transparent" BorderThickness="0"
                ToolTip="Заблокировать / разблокировать перемещение и изменение размера"
                Command="{Binding Tag.ToggleLockGreenhouseCommand,
                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding}">
            <Grid>
                <fa5:ImageAwesome Icon="Solid_Lock" Height="10" Foreground="#E53935"
                                  Visibility="{Binding IsLocked, Converter={StaticResource BoolToVisibility}}"/>
                <fa5:ImageAwesome Icon="Solid_LockOpen" Height="10" Foreground="#BDBDBD"
                                  Visibility="{Binding IsLocked, Converter={StaticResource NotBoolToVisibility}}"/>
            </Grid>
        </Button>

        <!-- Перемещение -->
        <Thumb Cursor="SizeAll" Width="{Binding DisplayWidth}" Height="{Binding DisplayHeight}"
               Opacity="0" Panel.ZIndex="10" DragDelta="DragThumb_DragDelta">
            <i:Interaction.Triggers>
                <!-- После отпускания — сохранить позицию в БД -->
                <i:EventTrigger EventName="DragCompleted">
                    <i:InvokeCommandAction
                        Command="{Binding Tag.SaveGreenhousePositionCommand,
                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </Thumb>

        <!-- Изменение размера — скрыто при блокировке -->
        <Thumb Width="10" Height="10" Cursor="SizeNWSE"
               HorizontalAlignment="Right" VerticalAlignment="Bottom"
               Panel.ZIndex="11"
               Visibility="{Binding IsLocked, Converter={StaticResource NotBoolToVisibility}}"
               DragDelta="ResizeThumb_DragDelta">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Rectangle Fill="#7B1FA2" Width="10" Height="10" RadiusX="2" RadiusY="2"/>
                </ControlTemplate>
            </Thumb.Template>
            <i:Interaction.Triggers>
                <!-- После отпускания — сохранить новый размер в БД -->
                <i:EventTrigger EventName="DragCompleted">
                    <i:InvokeCommandAction
                        Command="{Binding Tag.SaveGreenhousePositionCommand,
                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </Thumb>
    </Grid>
</UserControl>
