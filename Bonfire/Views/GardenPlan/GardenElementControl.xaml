<UserControl x:Class="Bonfire.Views.GardenPlan.GardenElementControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:m="clr-namespace:Bonfire.Models"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:vm="clr-namespace:Bonfire.ViewModels"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance {x:Type m:GardenElementFromViewModel}}"
             Width="{Binding Width}" Height="{Binding Height}"
             Focusable="True" FocusVisualStyle="{x:Null}">
    <UserControl.Style>
        <Style TargetType="UserControl">
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLocked}" Value="True">
                    <Setter Property="Cursor" Value="Arrow"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <UserControl.ToolTip>
        <StackPanel>
            <TextBlock FontWeight="SemiBold" Text="{Binding Name}"/>
            <TextBlock Foreground="#757575">
                <Run Text="{Binding TypeLabel, Mode=OneWay}"/>
                <Run Text="·"/>
                <Run Text="{Binding StateDisplayName, Mode=OneWay}"/>
            </TextBlock>
            <TextBlock Margin="0,2,0,0">
                <Run Text="Д"/>
                <Run Text="{Binding WidthMeters,  Mode=OneWay, StringFormat={}{0:F2}}"/>
                <Run Text="м  Ш"/>
                <Run Text="{Binding HeightMeters, Mode=OneWay, StringFormat={}{0:F2}}"/>
                <Run Text="м  ("/>
                <Run Text="{Binding AreaSquareMeters, Mode=OneWay, StringFormat={}{0:F1}}"/>
                <Run Text="м²)"/>
            </TextBlock>
            <TextBlock Foreground="#9E9E9E" Margin="0,4,0,0" FontSize="10">
                <Run Text="Двойной клик — схема посадок"/>
                <LineBreak/>
                <Run Text="Правый клик — контекстное меню"/>
            </TextBlock>
        </StackPanel>
    </UserControl.ToolTip>

    <UserControl.Resources>
        <Style x:Key="ResizeThumbStyle" TargetType="Thumb">
            <Setter Property="Width"  Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Rectangle Fill="{TemplateBinding Background}"
                                   Width="{TemplateBinding Width}"
                                   Height="{TemplateBinding Height}"
                                   RadiusX="2" RadiusY="2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!--
        Tag содержит GardenPlanViewModel (прокинут из DataTemplate в GardenPlanView).
        Используем его для привязки команд вместо навигации по дереву.
    -->
    <!--
        MouseLeftButtonDown срабатывает на UserControl-уровне НЕ работает:
        невидимый DragThumb (ZIndex=10) перехватывает событие и ставит e.Handled = true.
        Выделение вынесено в DragStarted на самом DragThumb.
        Правый клик — на UserControl, т.к. Thumb не перехватывает MouseRightButtonDown.
    -->
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="MouseRightButtonDown">
            <i:InvokeCommandAction
                Command="{Binding Tag.SelectElementCommand,
                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding}"/>
        </i:EventTrigger>
        <!-- Двойной клик — открыть схему посадок -->
        <i:EventTrigger EventName="MouseDoubleClick">
            <i:InvokeCommandAction
                Command="{Binding Tag.OpenPlantingGridCommand,
                    RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <!-- Компактный блок (отображается при малом масштабе) -->
        <Border Visibility="{Binding IsCompact, Converter={StaticResource BoolToVisibility}}"
                Background="{Binding TypeFill, Converter={StaticResource StringToBrushConverter}}"
                CornerRadius="3">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="BorderBrush" Value="{Binding TypeColor, Converter={StaticResource StringToBrushConverter}}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter Property="BorderThickness" Value="3"/>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#1976D2" BlurRadius="8" ShadowDepth="0"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <!-- Точка состояния по центру -->
            <Ellipse Width="8" Height="8" HorizontalAlignment="Center" VerticalAlignment="Center"
                     Fill="{Binding StateColor, Converter={StaticResource StringToBrushConverter}}"/>
        </Border>

        <!-- Основной блок элемента (скрывается в компактном режиме) -->
        <Border Visibility="{Binding IsCompact, Converter={StaticResource NotBoolToVisibility}}"
                Background="{Binding TypeFill, Converter={StaticResource StringToBrushConverter}}"
                CornerRadius="4" Padding="6,4">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="BorderBrush" Value="{Binding TypeColor, Converter={StaticResource StringToBrushConverter}}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter Property="BorderThickness" Value="3"/>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#1976D2" BlurRadius="8" ShadowDepth="0"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <DockPanel>
                <!-- Название + тип (шрифт адаптируется к зуму) -->
                <TextBlock DockPanel.Dock="Top" Text="{Binding Name}"
                           FontWeight="SemiBold"
                           FontSize="{Binding AdaptiveFontSize}"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock DockPanel.Dock="Top" Text="{Binding TypeLabel}"
                           FontSize="{Binding AdaptiveFontSize}"
                           Foreground="#757575"/>

                <!-- Статус-бейдж -->
                <Border DockPanel.Dock="Bottom"
                        Background="{Binding StateColor, Converter={StaticResource StringToBrushConverter}}"
                        CornerRadius="3" Padding="3,1" HorizontalAlignment="Left" Margin="0,4,0,0">
                    <TextBlock Text="{Binding StateDisplayName}"
                               Foreground="White" FontSize="9"/>
                </Border>

                <!-- Площадь -->
                <TextBlock DockPanel.Dock="Bottom" FontSize="10" Foreground="#9E9E9E" Margin="0,2,0,0">
                    <Run Text="{Binding AreaSquareMeters, Mode=OneWay, StringFormat={}{0:F1}}"/>
                    <Run Text=" м²"/>
                </TextBlock>

            </DockPanel>
        </Border>

        <!-- Ручка перемещения — через Thumb drag -->
        <Thumb x:Name="DragThumb" Cursor="SizeAll"
               Width="{Binding Width}" Height="{Binding Height}"
               Opacity="0" Panel.ZIndex="10"
               DragStarted="OnDragStarted"
               DragDelta="OnDragDelta"
               DragCompleted="OnMoveDragCompleted">
            <i:Interaction.Triggers>
                <!-- DragStarted: выделяем элемент командой VM -->
                <i:EventTrigger EventName="DragStarted">
                    <i:InvokeCommandAction
                        Command="{Binding Tag.SelectElementCommand,
                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}"/>
                </i:EventTrigger>
                <i:EventTrigger EventName="DragCompleted">
                    <i:InvokeCommandAction
                        Command="{Binding Tag.SaveElementPositionCommand,
                            RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </Thumb>

        <!-- Кнопка замка — верхний правый угол, над DragThumb -->
        <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                Width="18" Height="18" Panel.ZIndex="12" Padding="0"
                Cursor="Arrow" Background="Transparent" BorderThickness="0"
                ToolTip="Заблокировать / разблокировать перемещение и изменение размера"
                Command="{Binding Tag.ToggleLockElementCommand,
                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding}">
            <Grid>
                <fa5:ImageAwesome Icon="Solid_Lock" Height="9" Foreground="#E53935"
                                  Visibility="{Binding IsLocked, Converter={StaticResource BoolToVisibility}}"/>
                <fa5:ImageAwesome Icon="Solid_LockOpen" Height="9" Foreground="#BDBDBD"
                                  Visibility="{Binding IsLocked, Converter={StaticResource NotBoolToVisibility}}"/>
            </Grid>
        </Button>

        <!-- Ручка изменения размера (правый нижний угол) — скрыта при блокировке -->
        <Thumb Style="{StaticResource ResizeThumbStyle}"
               HorizontalAlignment="Right" VerticalAlignment="Bottom"
               Cursor="SizeNWSE" Panel.ZIndex="11"
               Visibility="{Binding IsLocked, Converter={StaticResource NotBoolToVisibility}}"
               DragStarted="OnDragStarted"
               DragDelta="ResizeThumb_DragDelta"
               DragCompleted="OnResizeDragCompleted">
            <i:Interaction.Triggers>
                <!-- DragStarted: выделяем элемент командой VM -->
                <i:EventTrigger EventName="DragStarted">
                    <i:InvokeCommandAction
                        Command="{Binding Tag.SelectElementCommand,
                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}"/>
                </i:EventTrigger>
                <!-- После отпускания — сохранить новый размер в БД -->
                <i:EventTrigger EventName="DragCompleted">
                    <i:InvokeCommandAction
                        Command="{Binding Tag.SaveElementPositionCommand,
                            RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </Thumb>
    </Grid>

    <UserControl.ContextMenu>
        <!--
            PlacementTarget = GardenElementControl (этот UserControl).
            PlacementTarget.Tag = GardenPlanViewModel (прокинут из DataTemplate).
            PlacementTarget.DataContext = GardenElementFromViewModel (текущий элемент).
        -->
        <ContextMenu>
            <MenuItem Header="Схема посадок"
                      Command="{Binding PlacementTarget.Tag.OpenPlantingGridCommand,
                          RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
            <Separator/>
            <!-- PlacementTarget.DataContext = GardenElementFromViewModel → CanGoTo* -->
            <MenuItem Header="Запланирована"
                      IsEnabled="{Binding PlacementTarget.DataContext.CanGoToPlanned,
                          RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      Command="{Binding PlacementTarget.Tag.ChangeElementStateCommand,
                          RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="PlannedState"/>
            <MenuItem Header="Подготовлена"
                      IsEnabled="{Binding PlacementTarget.DataContext.CanGoToPrepared,
                          RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      Command="{Binding PlacementTarget.Tag.ChangeElementStateCommand,
                          RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="PreparedState"/>
            <MenuItem Header="Активна"
                      IsEnabled="{Binding PlacementTarget.DataContext.CanGoToActive,
                          RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      Command="{Binding PlacementTarget.Tag.ChangeElementStateCommand,
                          RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="ActiveState"/>
            <MenuItem Header="Под паром"
                      IsEnabled="{Binding PlacementTarget.DataContext.CanGoToFallow,
                          RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      Command="{Binding PlacementTarget.Tag.ChangeElementStateCommand,
                          RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="FallowState"/>
            <MenuItem Header="Зимовка"
                      IsEnabled="{Binding PlacementTarget.DataContext.CanGoToResting,
                          RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      Command="{Binding PlacementTarget.Tag.ChangeElementStateCommand,
                          RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="RestingState"/>
            <Separator/>
            <MenuItem Header="Удалить"
                      Command="{Binding PlacementTarget.Tag.DeleteElementCommand,
                          RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      Foreground="Red"/>
        </ContextMenu>
    </UserControl.ContextMenu>
</UserControl>
